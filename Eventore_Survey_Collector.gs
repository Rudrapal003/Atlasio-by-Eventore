  'v_find','v_spend','v_calendar','v_hours','v_pain',
  'v_likely','v_disappointed','v_features','v_concern',
  'v_email','v_business','v_refer'
];

// ─── Survey HTML (base64-encoded so no escaping issues survive paste) ─────────
// Decoded at runtime via Utilities.base64Decode — pure ASCII, paste-safe.

var VENDOR_B64   = '';
var CUSTOMER_B64 = '';

function getHtml_(b64) {
  var bytes = Utilities.base64Decode(b64);
  return Utilities.newBlob(bytes).getDataAsString();
}

// ─── GET: serve survey pages ──────────────────────────────────────────────────

function doGet(e) {
  var type = (e && e.parameter && e.parameter.type) ? e.parameter.type : '';

  if (type === 'vendor') {
    return HtmlService.createHtmlOutput(getHtml_(VENDOR_B64))
      .setTitle('Eventore — Vendor Survey')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
  }

  if (type === 'customer') {
    return HtmlService.createHtmlOutput(getHtml_(CUSTOMER_B64))
      .setTitle('Eventore — Event Planning Survey')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
  }

  // Landing page
  var url = ScriptApp.getService().getUrl();
  var html = '<!doctype html><html><head>'
    + '<meta charset="utf-8">'
    + '<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">'
    + '<title>Eventore Surveys</title>'
    + '<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">'
    + '<style>'
    + 'body{font-family:Inter,system-ui,sans-serif;background:#F4F1EB;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;padding:20px;box-sizing:border-box}'
    + '.box{background:#fff;border-radius:20px;padding:40px 32px;max-width:440px;width:100%;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.09)}'
    + 'h1{font-family:Fraunces,Georgia,serif;color:#1F4E79;font-size:clamp(24px,6vw,32px);margin:0 0 6px;letter-spacing:-.02em}'
    + '.tag{color:#C9A227;font-style:italic;font-size:14px;font-weight:600;margin:0 0 18px;display:block}'
    + 'p{color:#64748B;font-size:15px;line-height:1.6;margin:0 0 28px}'
    + '.btn{display:block;padding:18px 20px;border-radius:14px;font-size:16px;font-weight:600;text-decoration:none;margin-bottom:12px}'
    + '.btn-v{background:#1F4E79;color:#fff}'
    + '.btn-c{background:#C9A227;color:#fff}'
    + '.foot{color:#94A3B8;font-size:12px;margin-top:20px}'
    + '</style></head><body>'
    + '<div class="box">'
    + '<h1>Eventore</h1>'
    + '<span class="tag">One stop. Every event.</span>'
    + '<p>Help us build the right product — pick the survey that fits you.</p>'
    + '<a class="btn btn-v" href="' + url + '?type=vendor">I am a Vendor / Event Professional</a>'
    + '<a class="btn btn-c" href="' + url + '?type=customer">I am Planning an Event</a>'
    + '<p class="foot">Takes about 4 minutes</p>'
    + '</div></body></html>';

  return HtmlService.createHtmlOutput(html)
    .setTitle('Eventore — Surveys')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

// ─── POST: save survey responses to Google Sheet ──────────────────────────────

function doPost(e) {
  try {
    var data    = JSON.parse(e.postData.contents);
    var type    = (data.survey === 'vendor') ? 'vendor' : 'customer';
    var columns = (type === 'vendor') ? VENDOR_COLUMNS : CUSTOMER_COLUMNS;
    var ss      = SpreadsheetApp.openById('1Oj9g4Xj5jvN3D2DsEXQjNaIKmJmf3amndgxQ9KpaZ64');
    var sheet   = ss.getSheetByName(type) || ss.insertSheet(type);

    if (sheet.getLastRow() === 0) {
      sheet.appendRow(columns);
      var hdr = sheet.getRange(1, 1, 1, columns.length);
      hdr.setFontWeight('bold').setBackground('#1F4E79').setFontColor('#FFFFFF');
      sheet.setFrozenRows(1);
      sheet.setColumnWidths(1, columns.length, 160);
    }

    var answers = data.answers || {};
    var row = columns.map(function(col) {
      if (col === 'submitted_at') return data.submitted_at || new Date().toISOString();
      if (col === 'user_agent')   return data.user_agent || '';
      var v = answers[col];
      if (v === undefined || v === null) return '';
      return Array.isArray(v) ? v.join('; ') : String(v);
    });
    sheet.appendRow(row);

    return ContentService
      .createTextOutput(JSON.stringify({ ok: true, survey: type, row: sheet.getLastRow() }))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({ ok: false, error: String(err) }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}
