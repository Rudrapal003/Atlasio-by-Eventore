  'v_category','v_years','v_events','v_team','v_cultural',
  'v_leads','v_spend','v_calendar','v_payments','v_hours',
  'v_pains','v_doublebook','v_lost_leads','v_knot',
  'v_likely','v_disappointed','v_value','v_concern',
