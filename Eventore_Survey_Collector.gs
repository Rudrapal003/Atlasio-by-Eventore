  'v_feat_calendar','v_feat_leads','v_feat_sync','v_feat_pay','v_feat_backup','v_feat_cultural','v_missing',
  'v_city','v_business','v_email','v_refer'
];

var CUSTOMER_COLUMNS = [
  'submitted_at','user_agent','user_role',
  'p_types','p_budget','p_location',
  'p_find','p_pain','p_time',
  'p_likely','p_disappointed','p_features','p_concern',
  'p_email','p_refer',
