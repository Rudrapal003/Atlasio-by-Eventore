# Copy to .env.local and fill in. Never commit .env.local.

# Supabase — shared with the main Eventore app (read access only on fd_* tables for now)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Public URL the app is deployed at (used for analytics + outbound link tracking)
VITE_PUBLIC_URL=https://eventore.ca

# Optional: Plausible / Umami analytics endpoint
VITE_ANALYTICS_DOMAIN=eventore.ca
VITE_ANALYTICS_SCRIPT=https://plausible.io/js/script.js

# Optional: feature flags
VITE_ENABLE_SPONSORED=true
VITE_ENABLE_OUTBOUND_TRACKING=true
