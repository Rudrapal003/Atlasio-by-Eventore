// ─── Main POST handler ────────────────────────────────────────────────────────

function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var surveyType = (data.survey === 'vendor') ? 'vendor' : 'customer';
    var columns    = (surveyType === 'vendor') ? VENDOR_COLUMNS : CUSTOMER_COLUMNS;

    var ss    = SpreadsheetApp.openById('1Oj9g4Xj5jvN3D2DsEXQjNaIKmJmf3amndgxQ9KpaZ64');
    var sheet = ss.getSheetByName(surveyType);

    if (!sheet) {
      sheet = ss.insertSheet(surveyType);
    }

    if (sheet.getLastRow() === 0) {
      sheet.appendRow(columns);
      var headerRange = sheet.getRange(1, 1, 1, columns.length);
      headerRange.setFontWeight('bold');
      headerRange.setBackground('#1F4E79');
      headerRange.setFontColor('#FFFFFF');
      sheet.setFrozenRows(1);
      sheet.setColumnWidths(1, columns.length, 160);
    }

    var answers = data.answers || {};

    var row = columns.map(function(col) {
      if (col === 'submitted_at') return data.submitted_at || new Date().toISOString();
      if (col === 'user_agent')   return data.user_agent || '';
      var val = answers[col];
      if (val === undefined || val === null) return '';
      if (Array.isArray(val)) return val.join('; ');
      return String(val);
    });

    sheet.appendRow(row);

    // Handle any extra question IDs not in predefined columns
    var knownCols = columns.reduce(function(acc, c) { acc[c] = true; return acc; }, {});
    var extraKeys = Object.keys(answers).filter(function(k) { return !knownCols[k]; });
    if (extraKeys.length > 0) {
      var lastCol = sheet.getLastColumn();
      var existingHeaders = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
      extraKeys.forEach(function(key) {
        if (existingHeaders.indexOf(key) === -1) {
          var newCol = sheet.getLastColumn() + 1;
          sheet.getRange(1, newCol).setValue(key).setFontWeight('bold');
          existingHeaders.push(key);
        }
        var colIdx = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0].indexOf(key) + 1;
        if (colIdx > 0) {
          sheet.getRange(sheet.getLastRow(), colIdx).setValue(
            Array.isArray(answers[key]) ? answers[key].join('; ') : String(answers[key])
          );
        }
      });
    }

    return ContentService
      .createTextOutput(JSON.stringify({ ok: true, survey: surveyType, row: sheet.getLastRow() }))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({ ok: false, error: String(err) }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

